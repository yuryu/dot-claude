{
  "model": "claude-fable-5[1m]",
  "permissions": {
    "allow": [
      "Bash(~/.claude/scripts/pr-review.sh:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(gh *)",
            "command": "~/.claude/scripts/gh-attribution-hook.sh",
            "timeout": 5,
            "statusMessage": "Checking gh attribution"
          }
        ]
      }
    ]
  },
  "enableWorkflows": true,
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "effortLevel": "high",
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": true,
  "editorMode": "normal"
}
